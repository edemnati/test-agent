# =============================================================================
# Configuration de l'Agent d'Analyse de Marché E-commerce
# Copiez ce fichier en .env et ajustez les valeurs selon votre environnement
# =============================================================================

# ─── Fournisseur LLM ──────────────────────────────────────────────────────────
# Valeurs possibles : ollama | openai | groq | openrouter
LLM_PROVIDER=ollama

# Nom du modèle selon le fournisseur
#  - Ollama   : llama3.2:3b | llama3.1:8b | mistral:7b | phi3:mini
#  - OpenAI   : gpt-4o-mini | gpt-4o
#  - Groq     : llama-3.3-70b-versatile | mixtral-8x7b-32768
#  - OpenRouter: meta-llama/llama-3.2-3b-instruct | mistralai/mistral-7b-instruct
LLM_MODEL=llama3.2:3b

# URL de base (pour Ollama local ou tout endpoint compatible OpenAI)
LLM_BASE_URL=http://localhost:11434

# Clé API (laisser vide pour Ollama local)
LLM_API_KEY=

# Température du LLM — 0.0 = déterministe, 1.0 = créatif
LLM_TEMPERATURE=0.1

# Timeout en secondes pour les appels LLM
LLM_TIMEOUT=120

# ─── Paramètres de l'agent ────────────────────────────────────────────────────
# Nombre maximum d'itérations (appels outils) avant arrêt forcé
AGENT_MAX_ITERATIONS=10

# ─── Données ──────────────────────────────────────────────────────────────────
# true = données simulées (développement/tests), false = APIs réelles
USE_MOCK_DATA=true

# ─── API REST ─────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false
